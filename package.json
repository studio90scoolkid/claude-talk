{
  "name": "claude-talk",
  "displayName": "Claude Talk",
  "description": "Two AI agents debate any topic to spark insights, expand ideas, and explore deeper — powered by Claude CLI",
  "version": "0.2.2",
  "publisher": "STUDIOCOOLKID",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/studio90scoolkid/claude-talk"
  },
  "icon": "icon.png",
  "keywords": ["ai", "debate", "claude", "anthropic", "talk", "agent", "discussion", "llm"],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "debate.start",
        "title": "Claude Talk: Start"
      },
      {
        "command": "debate.stop",
        "title": "Claude Talk: Stop"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
